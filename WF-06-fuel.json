      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 220]
    },
    {
      "parameters": {
        "url": "http://www.opinet.co.kr/api/avgSidoPrice.do",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "code",
              "value": "={{ $env.OPINET_API_KEY }}"
            },
            {
              "name": "out",
              "value": "json"
            },
