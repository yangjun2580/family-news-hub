      "id": "http-opinet-sido",
      "name": "오피넷 경기도 평균가",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 400]
    },
    {
      "parameters": {
        "jsCode": "// ── 오피넷 전국 평균 파싱 ─────────────────────────────────\nconst allData = $('오피넷 전국 평균가').item.json;\nconst sidoData = $('오피넷 경기도 평균가').item.json;\n\n// 오피넷 응답 구조: { RESULT: { OIL: [ {PRODCD, PRODNM, PRICE, DIFF} ] } }\nfunction parseOilData(data) {\n  const oils = data?.RESULT?.OIL || [];\n  const map = {};\n  for (const oil of oils) {\n    map[oil.PRODCD] = {\n      price: Math.round(parseFloat(oil.PRICE) || 0),\n      diff:  Math.round(parseFloat(oil.DIFF) || 0)\n    };\n  }\n  return map;\n}\n\n// 유종 코드\n// B027: 휘발유, D047: 경유, K015: LPG\nconst allMap = parseOilData(allData);\nconst sidoMap = parseOilData(sidoData);\n\n// 전국 평균\nconst national = {\n  region:       '전국평균',\n  gasoline:     allMap['B027']?.price || null,\n  diesel:       allMap['D047']?.price || null,\n  lpg:          allMap['K015']?.price || null,\n  gasoline_chg: allMap['B027']?.diff  || 0,\n  diesel_chg:   allMap['D047']?.diff  || 0,\n  lpg_chg:      allMap['K015']?.diff  || 0,\n  fetched_at:   new Date().toISOString()\n};\n\n// 경기도 평균\nconst gyeonggi = {\n  region:       '경기도',\n  gasoline:     sidoMap['B027']?.price || null,\n  diesel:       sidoMap['D047']?.price || null,\n  lpg:          sidoMap['K015']?.price || null,\n  gasoline_chg: sidoMap['B027']?.diff  || 0,\n  diesel_chg:   sidoMap['D047']?.diff  || 0,\n  lpg_chg:      sidoMap['K015']?.diff  || 0,\n  fetched_at:   new Date().toISOString()\n};\n\nconsole.log('전국 유가:', JSON.stringify(national));\nconsole.log('경기도 유가:', JSON.stringify(gyeonggi));\n\nreturn [\n  { json: national },\n  { json: gyeonggi }\n];"
      },
      "id": "code-parse-fuel",
      "name": "유가 데이터 파싱",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [700, 300]
    },
